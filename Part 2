import tkinter as tk

def calculate():
    try:
        actual_value = float(actual_entry.get())
    except ValueError:
        assessment_label.config(text="Assessment Value: Invalid input")
        tax_label.config(text="Property Tax: Invalid input")
        return
    assessment_value = actual_value * 0.60
    property_tax = (assessment_value / 100) * 0.75
    assessment_label.config(text=f"Assessment Value: ${assessment_value:.2f}")
    tax_label.config(text=f"Property Tax: ${property_tax:.2f}")

root = tk.Tk()
root.title("Property Tax Calculator")

tk.Label(root, text="Enter actual property value:").pack(anchor="w", padx=10, pady=(10, 0))
actual_entry = tk.Entry(root)
actual_entry.pack(padx=10, pady=5)

tk.Button(root, text="Calculate", command=calculate).pack(pady=5)

assessment_label = tk.Label(root, text="Assessment Value: ")
assessment_label.pack(anchor="w", padx=10)

tax_label = tk.Label(root, text="Property Tax: ")
tax_label.pack(anchor="w", padx=10, pady=(0, 10))

root.mainloop()
