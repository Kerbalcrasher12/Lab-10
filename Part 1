import tkinter as tk
from tkinter import messagebox


def calculate():
    rates = {"Daytime": 0.07, "Evening": 0.12, "Off-Peak": 0.05}
    try:
        minutes = float(minutes_entry.get())
    except ValueError:
        messagebox.showerror("Error", "Please enter a valid number of minutes.")
        return
    rate = rates[rate_var.get()]
    charge = minutes * rate
    messagebox.showinfo("Call Charge", f"Charge for the call: ${charge:.2f}")


root = tk.Tk()
root.title("Phone Call Rate Calculator")

rate_var = tk.StringVar(value="Daytime")

tk.Label(root, text="Select Rate Category:").pack(anchor="w", padx=10, pady=(10, 0))
for label in ["Daytime", "Evening", "Off-Peak"]:
    tk.Radiobutton(root, text=label, variable=rate_var, value=label).pack(anchor="w", padx=20)

tk.Label(root, text="Enter number of minutes:").pack(anchor="w", padx=10, pady=(10, 0))
minutes_entry = tk.Entry(root)
minutes_entry.pack(padx=10, pady=5)

tk.Button(root, text="Calculate", command=calculate).pack(pady=10)

root.mainloop()
